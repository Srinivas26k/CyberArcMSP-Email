# ─────────────────────────────────────────────────────────────
# CyberArc Outreach — .gitignore
# ─────────────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
wheels/
*.so
*.whl

# ── Virtual environments ─────────────────────────────────────
.venv/
venv/
env/

# ── Secrets & credentials (CRITICAL — never commit) ─────────
.env
.env.*
!.env.example
app/core/.vault_key
app/core/.vault_salt
scripts/.build_send.env

# ── Databases ────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
app/data/srvdb_store/

# ── Bundled binaries (downloaded at build time) ──────────────
bundled-uv/
bundled-python/

# ── Electron / Node ─────────────────────────────────────────
node_modules/
dist/
out/
*.exe
*.AppImage
*.deb
*.dmg
*.snap
*.rpm

# ── Build artifacts ──────────────────────────────────────────
*.zip
*.tar.gz

# ── Lock files (regenerated by package managers) ─────────────
package-lock.json
bun.lock

# ── OS junk ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~

# ── IDE ──────────────────────────────────────────────────────
.idea/
.vscode/
*.code-workspace

# ── Test logs ────────────────────────────────────────────────
tests/logs/

# ── Misc generated files ────────────────────────────────────
*.bak