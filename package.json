{
  "name": "cyberarc-outreach",
  "version": "2.0.0",
  "description": "CyberArc MSP — AI-Powered B2B Email Outreach Platform",
  "homepage": "https://cyberarcmsp.com",
  "main": "electron/main.js",
  "author": "Srinivas Nampalli <srinivasvarma764@gmail.com>",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --config",
    "dist:win": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.cyberarcmsp.outreach",
    "productName": "CyberArc Outreach",
    "copyright": "© 2026 CyberArc MSP",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "ui/**/*",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": ".",
        "to": "app",
        "filter": [
          "*.py",
          "pyproject.toml",
          "uv.lock",
          ".venv/**",
          "company.py",
          "prompt.py",
          "models.py",
          "database.py",
          "email_engine.py",
          "llm_client.py",
          "apollo_search.py",
          "server.py",
          ".env"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CyberArc Outreach"
    }
  }
}