{
  "name": "cyberarc-outreach",
  "version": "2.3.9",
  "description": "CyberArc MSP — AI-Powered B2B Email Outreach Platform",
  "homepage": "https://cyberarcmsp.com",
  "main": "electron/main.js",
  "author": "Srinivas Nampalli <srinivasvarma764@gmail.com>",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist:linux": "python3 scripts/download_uv.py linux && electron-builder --linux",
    "dist:win": "python3 scripts/download_uv.py win32 && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "dist:mac": "python3 scripts/download_uv.py darwin && electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.cyberarcmsp.outreach",
    "productName": "CyberArc Outreach",
    "copyright": "© 2026 CyberArc MSP",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "!ui/**",
      "!node_modules"
    ],
    "asarUnpack": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": ".",
        "to": "app",
        "filter": [
          "main.py",
          "pyproject.toml",
          "uv.lock",
          "app/**",
          "!app/**/__pycache__/**",
          "!app/**/*.pyc",
          "!app/**/*.pyo",
          "!app/**/*.db",
          "!app/**/.vault_key",
          "!app/**/.vault_salt",
          "!app/**/data/**",
          "!database.db",
          "!.env"
        ]
      },
      {
        "from": "ui",
        "to": "app/ui",
        "filter": ["**/*"]
      },
      {
        "from": "bundled-uv",
        "to": "app/bundled-uv",
        "filter": ["**"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CyberArc Outreach",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    }
  }
}
