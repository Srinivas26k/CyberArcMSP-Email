# ══════════════════════════════════════════════════════════
# SRV AI Outreach v2 — Environment Configuration
# CyberArc MSP
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════════

# ── LLM APIs ────────────────────────────────────────────
# Preferred provider: "groq" or "openrouter"
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE
OPENROUTER_API_KEY=sk-or-YOUR_OPENROUTER_KEY_HERE
# Optional: override the OpenRouter model
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Apollo.io ────────────────────────────────────────────
APOLLO_API_KEY=YOUR_APOLLO_KEY_HERE

# ── Sender Identity (shown in email footer) ────────────
SENDER_NAME=CyberArc MSP
SENDER_TITLE=Enterprise Solutions Architect
CALENDLY_URL=https://calendly.com/cyberarcmsp/30min

# ── Email Accounts ──────────────────────────────────────
# Accounts can be added directly from the Dashboard UI.
# Alternatively, pre-seed up to 5 via environment variables (all optional).
# Get Outlook App Password: mysignins.microsoft.com/security-info → + Add → App password
# Get Gmail App Password:   myaccount.google.com/apppasswords

# Account 1 (Outlook example)
OUTLOOK_EMAIL_1=contact@cyberarcmsp.com
OUTLOOK_PASS_1=xxxx xxxx xxxx xxxx
OUTLOOK_NAME_1=CyberArc MSP

# Account 2
OUTLOOK_EMAIL_2=rajesh.viprala@cyberarcmsp.com
OUTLOOK_PASS_2=xxxx xxxx xxxx xxxx
OUTLOOK_NAME_2=Rajesh Viprala

# Account 3
OUTLOOK_EMAIL_3=brian.johnson@cyberarcmsp.in
OUTLOOK_PASS_3=xxxx xxxx xxxx xxxx
OUTLOOK_NAME_3=Brian Johnson

# Account 4
OUTLOOK_EMAIL_4=julie.smith@cyberarcmsp.in
OUTLOOK_PASS_4=xxxx xxxx xxxx xxxx
OUTLOOK_NAME_4=Julie Smith

# Account 5
OUTLOOK_EMAIL_5=andrea.richards@cyberarcmsp.in
OUTLOOK_PASS_5=xxxx xxxx xxxx xxxx
